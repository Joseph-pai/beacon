:root{--bg:#07091a;--bg2:#0c1020;--card:#111827;--border:#1b3055;--primary:#0055bb;--accent:#00cfff;--accent2:#0088ee;--text:#ddeeff;--muted:#6a8aaa;--ok:#00cc88;--err:#ff4060}
*{margin:0;padding:0;box-sizing:border-box}body{background:var(--bg);color:var(--text);font-family:'Segoe UI',system-ui,sans-serif;overflow-x:hidden}
.btn{display:inline-flex;align-items:center;gap:.4rem;padding:.5rem 1.2rem;border-radius:7px;border:none;cursor:pointer;font-size:.875rem;font-weight:600;transition:all .2s;font-family:inherit}
.btn-p{background:linear-gradient(135deg,var(--primary),var(--accent2));color:#fff}.btn-p:hover{opacity:.85;transform:translateY(-1px)}
.btn-o{background:transparent;color:var(--accent);border:1px solid var(--accent)}.btn-o:hover{background:var(--accent);color:var(--bg)}
/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:.85rem 2rem;background:rgba(7,9,26,.9);backdrop-filter:blur(14px);border-bottom:1px solid var(--border)}
.logo{display:flex;align-items:center;gap:.7rem;cursor:pointer}
.lbox{width:34px;height:34px;background:linear-gradient(135deg,#0055bb,#00cfff);border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;flex-shrink:0}
.lname{font-size:1.1rem;font-weight:700}.lname span{color:var(--accent)}
.nlinks{display:flex;gap:2rem;list-style:none}.nlinks a{color:var(--muted);font-size:.88rem;text-decoration:none;transition:color .2s}.nlinks a:hover{color:var(--accent)}
/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;position:relative;overflow:hidden;padding:6rem 2rem 4rem}
canvas{position:absolute;inset:0;z-index:0}
.hi{position:relative;z-index:1;max-width:820px}
.badge{display:inline-block;padding:.3rem .9rem;border-radius:20px;background:rgba(0,207,255,.1);border:1px solid rgba(0,207,255,.3);color:var(--accent);font-size:.75rem;font-weight:700;letter-spacing:.1em;margin-bottom:1.5rem}
.hero h1{font-size:clamp(2rem,5.5vw,3.6rem);font-weight:800;line-height:1.15;margin-bottom:1.4rem}
.grad{background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero p{font-size:1.1rem;color:var(--muted);max-width:580px;margin:0 auto 2.5rem;line-height:1.75}
.hbtns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
.btn-lg{padding:.85rem 2rem;font-size:1rem;border-radius:9px}
.btn-repo{background:linear-gradient(135deg,#0055bb,#00cfff);color:#fff;border:none;font-weight:700;box-shadow:0 0 24px rgba(0,207,255,.3);transition:all .3s}.btn-repo:hover{box-shadow:0 0 40px rgba(0,207,255,.5);transform:translateY(-2px)}
/* SECTIONS */
.sec{padding:5rem 2rem;max-width:1100px;margin:0 auto}
.stitle{text-align:center;margin-bottom:3rem}.stitle h2{font-size:1.9rem;font-weight:700;margin-bottom:.6rem}.stitle p{color:var(--muted);font-size:.95rem}
.tag{display:inline-block;padding:.25rem .8rem;border-radius:20px;background:rgba(0,207,255,.1);border:1px solid rgba(0,207,255,.25);color:var(--accent);font-size:.72rem;font-weight:700;letter-spacing:.1em;margin-bottom:.9rem;text-transform:uppercase}
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(235px,1fr));gap:1.4rem}
.card{background:var(--card);border:1px solid var(--border);border-radius:13px;padding:1.75rem;transition:all .3s}.card:hover{border-color:var(--accent);transform:translateY(-4px);box-shadow:0 10px 35px rgba(0,207,255,.08)}
.card-ico{font-size:2rem;margin-bottom:1rem}.card h3{font-size:1.05rem;font-weight:700;margin-bottom:.65rem}.card p{color:var(--muted);font-size:.875rem;line-height:1.65}
.abg{background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.agrid{max-width:1100px;margin:0 auto;padding:5rem 2rem;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
@media(max-width:768px){.agrid{grid-template-columns:1fr;gap:2rem}.nlinks{display:none}}
.agrid h2{font-size:1.75rem;font-weight:700;margin-bottom:1rem}.agrid p{color:var(--muted);line-height:1.8;margin-bottom:.9rem;font-size:.93rem}
.stats{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem}
.stat{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:1.2rem;text-align:center}
.stn{font-size:1.75rem;font-weight:800;color:var(--accent)}.stl{font-size:.78rem;color:var(--muted);margin-top:.2rem}
.ctas{text-align:center;padding:5rem 2rem}
.ctab{background:linear-gradient(135deg,rgba(0,85,187,.15),rgba(0,207,255,.08));border:1px solid rgba(0,207,255,.28);border-radius:16px;padding:3rem 2rem;max-width:680px;margin:0 auto}
.ctab h2{font-size:1.75rem;font-weight:700;margin-bottom:.9rem}.ctab p{color:var(--muted);margin-bottom:2rem;line-height:1.75}
footer{background:var(--bg2);border-top:1px solid var(--border);padding:1.75rem 2rem;text-align:center;color:var(--muted);font-size:.82rem}
/* OVERLAY / MODAL */
.ov{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:500;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .25s}
.ov.on{opacity:1;pointer-events:all}
.modal{background:var(--card);border:1px solid var(--border);border-radius:15px;padding:2.25rem;width:100%;max-width:420px;position:relative;transform:scale(.92);transition:transform .25s}
.ov.on .modal{transform:scale(1)}
.modal h2{font-size:1.3rem;font-weight:700;margin-bottom:.4rem}.modal>.sub{color:var(--muted);font-size:.87rem;margin-bottom:1.75rem}
.mc{position:absolute;top:.9rem;right:1rem;background:none;border:none;color:var(--muted);font-size:1.3rem;cursor:pointer;padding:.25rem;line-height:1}.mc:hover{color:var(--text)}
.fg{margin-bottom:1.1rem}.fg label{display:block;font-size:.82rem;color:var(--muted);margin-bottom:.45rem}
.fg input{width:100%;padding:.7rem .95rem;background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:7px;color:var(--text);font-size:.92rem;outline:none;transition:border-color .2s;font-family:inherit}
.fg input:focus{border-color:var(--accent)}
.hint{background:rgba(0,207,255,.07);border:1px solid rgba(0,207,255,.2);border-radius:7px;padding:.65rem .9rem;font-size:.8rem;color:var(--muted);margin-bottom:1.4rem}
.hint strong{color:var(--accent)}
.lerr{color:var(--err);font-size:.82rem;margin-bottom:.9rem;display:none}
/* PREVIEW */
.pmod{background:var(--card);border:1px solid var(--border);border-radius:13px;width:92%;max-width:820px;max-height:86vh;display:flex;flex-direction:column}
.phead{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem;border-bottom:1px solid var(--border)}.phead h3{font-size:.95rem;font-weight:600}
.pbody{flex:1;overflow:auto;padding:1.25rem}
