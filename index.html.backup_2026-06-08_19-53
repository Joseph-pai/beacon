<script>
// ── PARTICLES ──
const cv=document.getElementById('cv'),ctx=cv.getContext('2d');
function rsz(){cv.width=cv.offsetWidth;cv.height=cv.offsetHeight}rsz();
window.addEventListener('resize',rsz);
class P{constructor(){this.reset()}reset(){this.x=Math.random()*cv.width;this.y=Math.random()*cv.height;this.vx=(Math.random()-.5)*.35;this.vy=(Math.random()-.5)*.35;this.s=Math.random()*1.4+.4;this.o=Math.random()*.45+.1}
step(){this.x+=this.vx;this.y+=this.vy;if(this.x<0||this.x>cv.width||this.y<0||this.y>cv.height)this.reset()}
draw(){ctx.beginPath();ctx.arc(this.x,this.y,this.s,0,Math.PI*2);ctx.fillStyle=`rgba(0,207,255,${this.o})`;ctx.fill()}}
const pts=Array.from({length:110},()=>new P());
function anim(){
  ctx.clearRect(0,0,cv.width,cv.height);
  pts.forEach(p=>{p.step();p.draw()});
  for(let i=0;i<pts.length;i++)for(let j=i+1;j<pts.length;j++){
    const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);
    if(d<95){ctx.beginPath();ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);
    ctx.strokeStyle=`rgba(0,207,255,${.1*(1-d/95)})`;ctx.lineWidth=.5;ctx.stroke()}}
  requestAnimationFrame(anim)}
anim();

// ── UTILS ──
function fd(d){return d.toLocaleDateString('zh-TW')+' '+d.toLocaleTimeString('zh-TW',{hour:'2-digit',minute:'2-digit'})}
function fsz(b){if(b<1024)return b+' B';if(b<1048576)return(b/1024).toFixed(1)+' KB';return(b/1048576).toFixed(1)+' MB'}
function ficon(n){const e=(n.split('.').pop()||'').toLowerCase(),m={js:'📜',ts:'📘',jsx:'⚛',tsx:'⚛',html:'🌐',css:'🎨',json:'📋',md:'📝',py:'🐍',swift:'🍎',kt:'🤖',dart:'💙',png:'🖼',jpg:'🖼',jpeg:'🖼',svg:'🎨',zip:'📦',pdf:'📄',txt:'📝',sh:'⚙',xml:'📋',yaml:'⚙',yml:'⚙',env:'⚙'};return m[e]||'📄'}

// ── OVERLAY HELPERS ──
function openOv(id){const el=document.getElementById(id);el.classList.add('on');const inp=el.querySelector('input');if(inp)setTimeout(()=>inp.focus(),200)}
function closeOv(id){document.getElementById(id).classList.remove('on')}
document.querySelectorAll('.ov').forEach(el=>el.addEventListener('click',e=>{if(e.target===el)el.classList.remove('on')}));

// ── AUTH ──
function openLogin(){openOv('loginOv')}
function closeLogin(){closeOv('loginOv');document.getElementById('lerr').style.display='none'}
function doLogin(){
  const u=document.getElementById('inp-user').value.trim();
  const p=document.getElementById('inp-pass').value;
  if(u==='admin'&&p==='601730'){
    closeLogin();
    document.getElementById('inp-pass').value='';
    showRepoPage(u);
  }else{
    document.getElementById('lerr').style.display='block';
    document.getElementById('inp-pass').value='';
    document.getElementById('inp-pass').focus();
  }
}
function showRepoPage(u){
  document.getElementById('landing').style.display='none';
  document.getElementById('repo').classList.add('on');
  document.getElementById('unameEl').textContent='👤 '+u;
  renderSb();
  const k=Object.keys(repos);
  if(k.length)selRepo(k[0]);else renderFiles();
}
function doLogout(){
  document.getElementById('repo').classList.remove('on');
  document.getElementById('landing').style.display='';
  curRepo=null;curPath=[];
}

// ── DATA ──
const repos={'MyApp範例':{},'WebProject':{}};
const vfs={
'MyApp範例':{
  'src':{t:'d',n:'src'},
  'src/App.js':{t:'f',n:'App.js',sz:512,dt:fd(new Date()),c:"import React from 'react';\n\nfunction App() {\n  return (\n    <div className=\"App\">\n      <h1>Hello AppForge!</h1>\n    </div>\n  );\n}\n\nexport default App;"},
  'src/index.js':{t:'f',n:'index.js',sz:210,dt:fd(new Date()),c:"import React from 'react';\nimport ReactDOM from 'react-dom';\nimport App from './App';\n\nReactDOM.render(<App />, document.getElementById('root'));"},
  'README.md':{t:'f',n:'README.md',sz:135,dt:fd(new Date()),c:"# MyApp範例\n\n這是一個範例 React APP 專案。\n\n## 安裝\n\n```bash\nnpm install\nnpm start\n```"},
  'package.json':{t:'f',n:'package.json',sz:290,dt:fd(new Date()),c:'{\n  "name": "myapp",\n  "version": "1.0.0",\n  "dependencies": {\n    "react": "^18.0.0",\n    "react-dom": "^18.0.0"\n  }\n}'}
},
'WebProject':{
  'index.html':{t:'f',n:'index.html',sz:340,dt:fd(new Date()),c:'<!DOCTYPE html>\n<html lang="zh-TW">\n<head>\n  <meta charset="UTF-8">\n  <title>WebProject</title>\n</head>\n<body>\n  <h1>歡迎使用 WebProject</h1>\n</body>\n</html>'},
  'css':{t:'d',n:'css'},
  'css/style.css':{t:'f',n:'style.css',sz:180,dt:fd(new Date()),c:'body {\n  margin: 0;\n  font-family: sans-serif;\n  background: #07091a;\n  color: #ddeeff;\n}'}
}};
let curRepo=null,curPath=[];

// ── SIDEBAR ──
function renderSb(){
  const el=document.getElementById('sbList');el.innerHTML='';
  Object.keys(repos).forEach(n=>{
    const d=document.createElement('div');
    d.className='ri'+(curRepo===n?' on':'');
    d.innerHTML=`<span>📦</span><span style="overflow:hidden;text-overflow:ellipsis">${n}</span>`;
    d.onclick=()=>selRepo(n);el.appendChild(d)});
}
function selRepo(n){curRepo=n;curPath=[];renderSb();renderBC();renderFiles()}

// ── BREADCRUMB ──
function renderBC(){
  const el=document.getElementById('bcEl');
  if(!curRepo){el.innerHTML='';return}
  let h=`<span class="bcl" onclick="navTo(-1)">📦 ${curRepo}</span>`;
  curPath.forEach((s,i)=>{
    h+=`<span class="bcs">/</span>`;
    if(i===curPath.length-1)h+=`<span class="bcc">${s}</span>`;
    else h+=`<span class="bcl" onclick="navTo(${i})">${s}</span>`;
  });
  el.innerHTML=h;
}
function navTo(i){curPath=i===-1?[]:curPath.slice(0,i+1);renderBC();renderFiles()}

// ── FILES ──
function pfx(){return curPath.length?curPath.join('/')+'/':\'\'}
function getItems(){
  if(!curRepo)return[];
  const data=vfs[curRepo]||{},pre=pfx(),items=[],seen=new Set();
  Object.keys(data).forEach(k=>{
    if(!k.startsWith(pre))return;
    const rest=k.slice(pre.length);if(!rest)return;
    const parts=rest.split('/'),top=parts[0];
    if(seen.has(top))return;seen.add(top);
    if(parts.length===1)items.push({key:k,...data[k]});
    else items.push({key:pre+top,t:'d',n:top});
  });
  return items.sort((a,b)=>a.t!==b.t?a.t==='d'?-1:1:a.n.localeCompare(b.n));
}
function renderFiles(){
  const el=document.getElementById('flistEl');
  if(!curRepo){el.innerHTML='<div class="empty"><div class="eico">📦</div><p>請從左側選擇或新增專案</p></div>';return}
  const items=getItems();
  if(!items.length){el.innerHTML='<div class="empty"><div class="eico">📂</div><p>此資料夾是空的，請上傳檔案或新增資料夾</p></div>';return}
  const rows=items.map(it=>{
    const isD=it.t==='d',ico=isD?'📁':ficon(it.n),sz=isD?'—':fsz(it.sz||0),dt=it.dt||'—';
    const kk=it.key.replace(/'/g,"\\'"),nn=it.n.replace(/'/g,"\\'");
    return`<tr>
      <td><div class="fn" onclick="${isD?`enterDir('${nn}')`:`pvFile('${kk}')`}"><span class="fi">${ico}</span><span class="fnt">${it.n}</span></div></td>
      <td class="fm">${sz}</td><td class="fm">${dt}</td>
      <td><div class="fa">
        ${!isD?`<button class="bs bi" onclick="dlFile('${kk}')">⬇</button>`:''}
        <button class="bs bd" onclick="delItem('${kk}','${it.t}')">🗑</button>
      </div></td></tr>`;
  }).join('');
  el.innerHTML=`<table class="ftbl"><thead><tr><th>名稱</th><th>大小</th><th>修改時間</th><th>操作</th></tr></thead><tbody>${rows}</tbody></table>`;
}
function enterDir(n){curPath.push(n);renderBC();renderFiles()}

// ── UPLOAD ──
function trigUp(){if(!curRepo){showToast('請先選擇一個專案','t-err');return}document.getElementById('fupInp').click()}
function handleUp(e){
  const files=e.target.files;if(!files.length)return;
  const pre=pfx();let done=0;
  Array.from(files).forEach(f=>{
    const isText=/\.(js|ts|jsx|tsx|json|html|css|md|py|swift|kt|dart|txt|sh|xml|yaml|yml|env|gitignore|vue|rs|go|java|c|cpp|h|rb|php)$/i.test(f.name)||f.type.startsWith('text/');
    const r=new FileReader();
    r.onload=ev=>{
      const key=pre+f.name;
      if(!vfs[curRepo])vfs[curRepo]={};
      vfs[curRepo][key]={t:'f',n:f.name,sz:f.size,dt:fd(new Date()),c:isText?ev.target.result:'[二進位檔案，無法預覽文字內容]'};
      if(++done===files.length){renderFiles();showToast(`✅ 上傳 ${done} 個檔案完成`,'t-ok')}
    };
    if(isText)r.readAsText(f,);else r.readAsDataURL(f);
  });
  e.target.value='';
}

// ── PREVIEW ──
function pvFile(key){
  const it=(vfs[curRepo]||{})[key];if(!it)return;
  document.getElementById('pvTitle').textContent='📄 '+it.n;
  document.getElementById('pvContent').textContent=it.c||'[無法預覽此檔案]';
  openOv('pvOv');
}
function closePv(){closeOv('pvOv')}

// ── DOWNLOAD FILE ──
function dlFile(key){
  const it=(vfs[curRepo]||{})[key];if(!it)return;
  const blob=new Blob([it.c||''],{type:'text/plain;charset=utf-8'});
  const url=URL.createObjectURL(blob),a=document.createElement('a');
  a.href=url;a.download=it.n;a.click();URL.revokeObjectURL(url);
  showToast(`⬇ 已下載 ${it.n}`,'t-inf');
}

// ── DOWNLOAD ZIP ──
async function dlZip(){
  if(!curRepo){showToast('請先選擇一個專案','t-err');return}
  const data=vfs[curRepo]||{};
  const keys=Object.keys(data).filter(k=>data[k].t==='f');
  if(!keys.length){showToast('此專案沒有任何檔案','t-err');return}
  showToast('⏳ 正在打包 ZIP...','t-inf');
  const zip=new JSZip();
  keys.forEach(k=>zip.file(k,(data[k].c||'')));
  const blob=await zip.generateAsync({type:'blob'});
  const url=URL.createObjectURL(blob),a=document.createElement('a');
  a.href=url;a.download=curRepo+'.zip';a.click();URL.revokeObjectURL(url);
  showToast(`📦 已下載 ${curRepo}.zip`,'t-ok');
}

// ── DELETE ──
function delItem(key,type){
  const nm=key.split('/').pop();
  if(!confirm(`確定要刪除「${nm}」嗎？`))return;
  const data=vfs[curRepo];
  if(type==='d')Object.keys(data).filter(k=>k===key||k.startsWith(key+'/')).forEach(k=>delete data[k]);
  else delete data[key];
  renderFiles();showToast('🗑 已刪除','t-inf');
}

// ── CREATE FOLDER ──
function createFolder(){
  const n=document.getElementById('nfInp').value.trim();
  if(!n){showToast('請輸入資料夾名稱','t-err');return}
  if(!curRepo){showToast('請先選擇專案','t-err');return}
  const key=pfx()+n;
  if(!vfs[curRepo])vfs[curRepo]={};
  vfs[curRepo][key]={t:'d',n};
  vfs[curRepo][key+'/.gitkeep']={t:'f',n:'.gitkeep',sz:0,dt:fd(new Date()),c:''};
  closeOv('nfOv');document.getElementById('nfInp').value='';
  renderFiles();showToast(`📂 已建立資料夾「${n}」`,'t-ok');
}

// ── CREATE REPO ──
function createRepo(){
  const n=document.getElementById('nrInp').value.trim();
  if(!n){showToast('請輸入專案名稱','t-err');return}
  if(repos[n]){showToast('此專案名稱已存在','t-err');return}
  repos[n]={};vfs[n]={};
  closeOv('nrOv');document.getElementById('nrInp').value='';
  selRepo(n);showToast(`📦 已建立專案「${n}」`,'t-ok');
}

// ── TOAST ──
let tt;
function showToast(msg,cls='t-inf'){
  const el=document.getElementById('toastEl');
  el.textContent=msg;el.className='toast '+cls+' on';
  clearTimeout(tt);tt=setTimeout(()=>el.classList.remove('on'),3200);
}
</script>
