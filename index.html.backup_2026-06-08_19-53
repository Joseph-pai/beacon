#repo{display:none;min-height:100vh;flex-direction:column}#repo.on{display:flex}
.rnav{display:flex;align-items:center;justify-content:space-between;padding:.9rem 1.5rem;background:var(--bg2);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100}
